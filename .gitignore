*.cover
coverage.xml

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
.docker/
docker-compose.override.yml
docker-compose.override.yaml

# SSL certificates (do NOT commit)
docker/nginx/ssl/*.pem
docker/nginx/ssl/*.key
docker/nginx/ssl/*.crt
docker/nginx/ssl/*.csr

# ---------------------------------------------------------------------------
# Logs & Databases
# ---------------------------------------------------------------------------
*.log
*.sqlite
*.sqlite3
*.db

# ---------------------------------------------------------------------------
