# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
.eggs/
dist/
build/
*.egg
.venv/
venv/
env/
*.whl
*.manifest
*.spec

# Python virtual environment
.ai-engine/.venv/
.ai-engine/venv/
.venv/
venv/

# Jupyter Notebook
.ipynb_checkpoints/

# pytest
.pytest_cache/
htmlcov/
.coverage
