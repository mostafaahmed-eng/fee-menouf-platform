# =============================================================================
# FEE-MENOUF Smart University Platform - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# =============================================================================

# ---------------------------------------------------------------------------
# APPLICATION
# ---------------------------------------------------------------------------
NODE_ENV=production
APP_NAME=FEE-MENOUF-Smart-University
APP_PORT=4000
FRONTEND_PORT=3000
AI_ENGINE_PORT=8000
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ---------------------------------------------------------------------------
# DATABASE (PostgreSQL + pgvector)
# ---------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fee_menouf_platform
DB_USER=postgres
DB_PASS=your_strong_db_password_here
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_SSL_ENABLED=true
DB_SSL_CA_PATH=/etc/ssl/certs/ca-certificates.crt
DB_SYNCHRONIZE=false
DB_LOGGING=false

# ---------------------------------------------------------------------------
# REDIS (Caching, Bull queues, session store)
# ---------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB_INDEX=0
REDIS_TLS_ENABLED=false

# ---------------------------------------------------------------------------
# JWT AUTHENTICATION
# ---------------------------------------------------------------------------
# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=your_jwt_access_secret_min_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_ISSUER=fee-menouf-university
JWT_AUDIENCE=fee-menouf-platform

# ---------------------------------------------------------------------------
# ENCRYPTION (AES-256-GCM for sensitive data at rest)
# ---------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your_64_character_hex_encryption_key_here
ENCRYPTION_IV_PREFIX=feemenouf2026

# ---------------------------------------------------------------------------
# OPENAI / AI ENGINE
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_ORGANIZATION=org-your-org-id
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7
OPENAI_TIMEOUT_MS=30000

# ---------------------------------------------------------------------------
# AI ENGINE (Python / FastAPI)
# ---------------------------------------------------------------------------
AI_ENGINE_WORKERS=4
AI_ENGINE_MAX_CONCURRENT=10
AI_ENGINE_RATE_LIMIT_PER_MIN=60
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_EMBEDDING_DIMENSIONS=1536

# ---------------------------------------------------------------------------
# SMTP (Email — transactional notifications, password reset)
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=your_smtp_password_or_api_key
SMTP_FROM_NAME=FEE-MENOUF Platform
SMTP_FROM_EMAIL=noreply@fee-menouf.edu.eg
SMTP_REPLY_TO=support@fee-menouf.edu.eg

# ---------------------------------------------------------------------------
# MINIO (S3-compatible object storage for file uploads)
# ---------------------------------------------------------------------------
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_minio_strong_password
MINIO_USE_SSL=false
MINIO_REGION=us-east-1
MINIO_DEFAULT_BUCKET=fee-menouf-uploads
MINIO_TMP_BUCKET=fee-menouf-temp

# ---------------------------------------------------------------------------
# S3 COMPATIBLE STORAGE (Alternative/MinIO API)
# ---------------------------------------------------------------------------
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=your_s3_access_key_here
S3_SECRET_KEY=your_s3_secret_key_here
S3_BUCKET=fee-menouf-uploads
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# ---------------------------------------------------------------------------
# GOOGLE MAPS
# ---------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ---------------------------------------------------------------------------
# FRONTEND (Next.js 15)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=https://api.your-domain.com
NEXT_PUBLIC_WS_URL=wss://api.your-domain.com
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# ---------------------------------------------------------------------------
# RATE LIMITING
# ---------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_MAX_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOGIN_WINDOW_MINUTES=15

# ---------------------------------------------------------------------------
# SESSION
# ---------------------------------------------------------------------------
SESSION_SECRET=your_session_secret_at_least_32_chars
SESSION_MAX_AGE_MS=86400000

# ---------------------------------------------------------------------------
# LOGGING & MONITORING
# ---------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# ---------------------------------------------------------------------------
# FILE UPLOADS
# ---------------------------------------------------------------------------
UPLOAD_MAX_FILE_SIZE_MB=50
UPLOAD_ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,doc,docx,xlsx,pptx,mp4,webm
UPLOAD_PATH=uploads

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
CORS_ORIGINS=https://your-domain.com,https://admin.your-domain.com
CORS_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_CREDENTIALS=true

# ---------------------------------------------------------------------------
# SECURITY
# ---------------------------------------------------------------------------
# Generate with: openssl rand -hex 16
CSRF_SECRET=your_csrf_secret_hex
BCRYPT_SALT_ROUNDS=12
HELMET_ENABLED=true
HELMET_CONTENT_SECURITY_POLICY=default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self' https://api.your-domain.com wss://api.your-domain.com

# ---------------------------------------------------------------------------
# CACHE
# ---------------------------------------------------------------------------
CACHE_TTL_MS=300000
CACHE_ENABLED=true
