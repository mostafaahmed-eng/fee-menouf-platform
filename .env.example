# =============================================================================
# FEE-MENOUF Smart University Platform - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# Then generate secrets with:
#   openssl rand -hex 64   (for JWT secrets)
#   openssl rand -hex 32   (for encryption key)
# =============================================================================

# ---------------------------------------------------------------------------
# APPLICATION
# ---------------------------------------------------------------------------
NODE_ENV=production
APP_NAME=FEE-MENOUF-Smart-University
APP_PORT=4000
FRONTEND_PORT=3000
AI_ENGINE_PORT=8000
NGINX_HTTP_PORT=8888
NGINX_HTTPS_PORT=443

# ---------------------------------------------------------------------------
# DATABASE (PostgreSQL)
# ---------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fee_menouf_platform
DB_USER=postgres
DB_PASS=your_db_password
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_SSL_ENABLED=false
DB_SSL_CA_PATH=/etc/ssl/certs/ca-certificates.crt
DB_SYNCHRONIZE=false
DB_LOGGING=false

# ---------------------------------------------------------------------------
# REDIS
# ---------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB_INDEX=0
REDIS_TLS_ENABLED=false

# ---------------------------------------------------------------------------
# JWT AUTHENTICATION
# ---------------------------------------------------------------------------
JWT_ACCESS_SECRET=generate_with_openssl_rand_hex_64
JWT_REFRESH_SECRET=generate_with_openssl_rand_hex_64
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_ISSUER=fee-menouf-university
JWT_AUDIENCE=fee-menouf-platform

# ---------------------------------------------------------------------------
# ENCRYPTION (AES-256-GCM)
# ---------------------------------------------------------------------------
ENCRYPTION_KEY=generate_with_openssl_rand_hex_32
ENCRYPTION_IV_PREFIX=feemenouf2026

# ---------------------------------------------------------------------------
# OPENAI / AI ENGINE (optional - rule-based fallback available)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_ORGANIZATION=org-your-org-id
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7
OPENAI_TIMEOUT_MS=30000

# ---------------------------------------------------------------------------
# AI ENGINE
# ---------------------------------------------------------------------------
AI_ENGINE_WORKERS=4
AI_ENGINE_MAX_CONCURRENT=10
AI_ENGINE_RATE_LIMIT_PER_MIN=60
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_EMBEDDING_DIMENSIONS=1536

# ---------------------------------------------------------------------------
# SMTP (Email)
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=your_smtp_password
SMTP_FROM_NAME=FEE-MENOUF Platform
SMTP_FROM_EMAIL=noreply@fee-menouf.edu.eg
SMTP_REPLY_TO=support@fee-menouf.edu.eg

# ---------------------------------------------------------------------------
# MINIO (Object Storage)
# ---------------------------------------------------------------------------
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_USE_SSL=false
MINIO_REGION=us-east-1
MINIO_DEFAULT_BUCKET=fee-menouf-uploads
MINIO_TMP_BUCKET=fee-menouf-temp

# ---------------------------------------------------------------------------
# S3 COMPATIBLE STORAGE
# ---------------------------------------------------------------------------
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=fee-menouf-uploads
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# ---------------------------------------------------------------------------
# GOOGLE MAPS
# ---------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ---------------------------------------------------------------------------
# FRONTEND (Next.js)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8888/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8888/ws
NEXT_PUBLIC_APP_URL=http://localhost
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# ---------------------------------------------------------------------------
# RATE LIMITING
# ---------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_MAX_LOGIN_ATTEMPTS=100
RATE_LIMIT_LOGIN_WINDOW_MINUTES=15

# ---------------------------------------------------------------------------
# SESSION
# ---------------------------------------------------------------------------
SESSION_SECRET=generate_with_openssl_rand_hex_32
SESSION_MAX_AGE_MS=86400000

# ---------------------------------------------------------------------------
# LOGGING & MONITORING
# ---------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# ---------------------------------------------------------------------------
# FILE UPLOADS
# ---------------------------------------------------------------------------
UPLOAD_MAX_FILE_SIZE_MB=50
UPLOAD_ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,doc,docx,xlsx,pptx,mp4,webm
UPLOAD_PATH=uploads

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173
CORS_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_CREDENTIALS=true

# ---------------------------------------------------------------------------
# SECURITY
# ---------------------------------------------------------------------------
CSRF_SECRET=generate_with_openssl_rand_hex_16
BCRYPT_SALT_ROUNDS=12
HELMET_ENABLED=true
HELMET_CONTENT_SECURITY_POLICY=default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self' http://localhost:* ws://localhost:*

# ---------------------------------------------------------------------------
# CACHE
# ---------------------------------------------------------------------------
CACHE_TTL_MS=300000
CACHE_ENABLED=true
